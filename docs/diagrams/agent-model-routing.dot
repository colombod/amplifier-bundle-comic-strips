digraph agent_routing {
  // Global settings
  rankdir=LR;
  bgcolor="transparent";
  fontname="Helvetica Neue,Helvetica,Arial,sans-serif";
  node [fontname="Helvetica Neue,Helvetica,Arial,sans-serif", fontsize=11];
  edge [fontname="Helvetica Neue,Helvetica,Arial,sans-serif", fontsize=9];
  nodesep=0.4;
  ranksep=0.8;

  // Title
  labelloc="t";
  label=<<B><FONT POINT-SIZE="16">Agent Model Routing &amp; Image Selection</FONT></B>>;
  labeljust="c";

  // --- Column 1: Agents ---
  subgraph cluster_agents {
    label=<<B>Agents</B>>;
    style="rounded,filled"; fillcolor="#F5F5F5"; color="#BDBDBD";
    fontsize=12; margin=16;

    sc [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD ALIGN="LEFT"><B>style-curator</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">Loads style packs, builds</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">visual direction guide</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9"
    ];

    sw [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD ALIGN="LEFT"><B>storyboard-writer</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">Characters, panel sequence,</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">dialogue, camera angles</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9"
    ];

    cd [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD ALIGN="LEFT"><B>character-designer</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">Crafts reference sheet</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">prompts per character</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9"
    ];

    pa [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD ALIGN="LEFT"><B>panel-artist</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">Generates panel images,</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">vision self-review loop</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D"
    ];

    ca [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD ALIGN="LEFT"><B>cover-artist</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">Cover image + branding,</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">vision self-review loop</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D"
    ];

    comp [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD ALIGN="LEFT"><B>strip-compositor</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">Analyzes panels, places</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9" COLOR="#666666">bubbles, builds HTML</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E8F5E9", color="#81C784"
    ];
  }

  // --- Column 2: Routing Matrix Roles ---
  subgraph cluster_roles {
    label=<<B>Routing Matrix Roles</B>>;
    style="rounded,filled"; fillcolor="#F3E5F5"; color="#CE93D8";
    fontsize=12; margin=16;

    role_creative [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD><B>creative</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">Opus / GPT-5 tier</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">aesthetic judgment</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#F3E5F5", color="#CE93D8"
    ];

    role_imagegen [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD><B>image-gen</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">image creation</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">models</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#F3E5F5", color="#CE93D8"
    ];

    role_vision [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD><B>vision</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">multimodal analysis</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">screenshot review</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#F3E5F5", color="#CE93D8"
    ];
  }

  // --- Column 3: Image Model Selection ---
  subgraph cluster_imgsel {
    label=<<B>Image Model Selection</B><BR/><FONT POINT-SIZE="9" COLOR="#555555">tool-comic-image-gen bridge</FONT>>;
    style="rounded,filled"; fillcolor="#FFF3E0"; color="#FFB74D";
    fontsize=12; margin=16;

    selector [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD COLSPAN="2"><B>select_model()</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">1.</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Filter by available providers</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">2.</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Reference image support?</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">3.</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Style category match</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">4.</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Detail level filter</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">5.</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Composition task bias</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">6.</FONT></TD><TD ALIGN="LEFT"><FONT POINT-SIZE="9">Cost optimization</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFF8E1", color="#FFB74D"
    ];

    openai_models [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD><B>OpenAI</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">gpt-image-1.5</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">gpt-image-1</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">gpt-image-1-mini</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">dall-e-3</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">dall-e-2</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFCCBC", color="#FF8A65"
    ];

    gemini_models [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD><B>Gemini</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">gemini-3-pro-image *</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">gemini-3.1-flash-image</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">gemini-2.5-flash-image</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">gemini-2.0-flash</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#C8E6C9", color="#66BB6A"
    ];

    imagen_models [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD><B>Imagen</B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">imagen-4.0-ultra</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">imagen-4.0</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="9">imagen-4.0-fast</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#C8E6C9", color="#66BB6A"
    ];

    weather [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
        <TR><TD><B>StrongDM Weather Report</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">"UX Ideation" benchmarks</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">inform composition_strength</FONT></TD></TR>
      </TABLE>>,
      shape=note, style="filled", fillcolor="#FFF9C4", color="#F9A825"
    ];

    selector -> openai_models [color="#FF8A65"];
    selector -> gemini_models [color="#66BB6A"];
    selector -> imagen_models [color="#66BB6A", style=dashed, label=<<FONT POINT-SIZE="8" COLOR="#999999">no ref images</FONT>>];
    weather -> selector [style=dashed, color="#F9A825", label=<<FONT POINT-SIZE="8" COLOR="#999999">ratings</FONT>>];
  }

  // --- Edges: Agents -> Roles ---
  sc -> role_creative [color="#90CAF9", label=<<FONT POINT-SIZE="8" COLOR="#1565C0">primary</FONT>>];
  sw -> role_creative [color="#90CAF9", label=<<FONT POINT-SIZE="8" COLOR="#1565C0">primary</FONT>>];
  cd -> role_creative [color="#90CAF9", label=<<FONT POINT-SIZE="8" COLOR="#1565C0">primary</FONT>>];

  pa -> role_imagegen [color="#FFB74D", label=<<FONT POINT-SIZE="8" COLOR="#E65100">primary</FONT>>];
  pa -> role_vision [color="#FFB74D", style=dashed, label=<<FONT POINT-SIZE="8" COLOR="#999999">fallback</FONT>>];
  pa -> role_creative [color="#FFB74D", style=dashed];

  ca -> role_imagegen [color="#FFB74D", label=<<FONT POINT-SIZE="8" COLOR="#E65100">primary</FONT>>];
  ca -> role_vision [color="#FFB74D", style=dashed, label=<<FONT POINT-SIZE="8" COLOR="#999999">fallback</FONT>>];
  ca -> role_creative [color="#FFB74D", style=dashed];

  comp -> role_vision [color="#81C784", label=<<FONT POINT-SIZE="8" COLOR="#2E7D32">primary</FONT>>];
  comp -> role_creative [color="#81C784", style=dashed, label=<<FONT POINT-SIZE="8" COLOR="#999999">fallback</FONT>>];

  // --- Edges: Roles -> Image Selection ---
  // image-gen agents also trigger the bridge tool internally
  role_imagegen -> selector [color="#CE93D8", style=bold, label=<<FONT POINT-SIZE="8" COLOR="#7B1FA2">triggers</FONT>>];

  // Footnote
  note [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="1">
      <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#999999">* gemini-3-pro-image-preview = "Nano Banana Pro"</FONT></TD></TR>
      <TR><TD ALIGN="LEFT"><FONT POINT-SIZE="8" COLOR="#999999">  StrongDM top pick for UX Ideation (composition)</FONT></TD></TR>
    </TABLE>>,
    shape=plaintext
  ];
}
