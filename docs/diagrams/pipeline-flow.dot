digraph pipeline {
  // Global settings
  rankdir=TB;
  bgcolor="transparent";
  fontname="Helvetica Neue,Helvetica,Arial,sans-serif";
  node [fontname="Helvetica Neue,Helvetica,Arial,sans-serif", fontsize=11];
  edge [fontname="Helvetica Neue,Helvetica,Arial,sans-serif", fontsize=9];
  newrank=true;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.6;

  // Title
  labelloc="t";
  label=<<B><FONT POINT-SIZE="16">Comic Generation Pipeline v8</FONT></B>>;
  labeljust="c";

  // Input
  input [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
      <TR><TD><B>events.jsonl</B></TD></TR>
      <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">Amplifier session log</FONT></TD></TR>
    </TABLE>>,
    shape=note, style="filled", fillcolor="#E8F4FD", color="#90CAF9",
    width=2.0
  ];

  // Stage 1 cluster
  subgraph cluster_stage1 {
    label=<<B>Stage 1 -- Research &amp; Storyboard</B><BR/><FONT POINT-SIZE="9" COLOR="#555555">text-only, low cost</FONT>>;
    style="rounded,filled"; fillcolor="#F5F5F5"; color="#BDBDBD";
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif"; fontsize=12;
    margin=16;

    init [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>1. Init Project</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">style-curator</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.2
    ];

    research [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>2. Research</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">stories:story-researcher</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">agent_id + bundle mapping</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.2
    ];

    style_curation [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>3. Style Curation</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">style-curator</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.2
    ];

    storyboard [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>4. Storyboard</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">storyboard-writer</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">+ stories:content-strategist</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">+ stories:case-study-writer</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">LAYOUT-FIRST: picks page layouts</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">emits aspect_ratio per panel</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">emits metadata.agent_id per char</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.8
    ];

    update_title [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>4b. Update Issue Title</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">style-curator</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">storyboard.title → issue.json</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.2
    ];

    init -> research -> style_curation -> storyboard -> update_title [color="#90CAF9"];
  }

  // Data flow annotations (between stages)
  storyboard_data [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32"><B>Storyboard outputs:</B></FONT></TD></TR>
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">page_layouts[ ] → layout ID per page</FONT></TD></TR>
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">panel_list[ ] → aspect_ratio per panel</FONT></TD></TR>
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">character_list[ ] → metadata.agent_id</FONT></TD></TR>
    </TABLE>>,
    shape=none, margin=0
  ];

  // Approval gate
  gate [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
      <TR><TD><B>APPROVAL GATE</B></TD></TR>
      <TR><TD><FONT POINT-SIZE="9">Review storyboard, characters &amp; layouts</FONT></TD></TR>
    </TABLE>>,
    shape=diamond, style="filled", fillcolor="#FFF9C4", color="#F9A825",
    width=3.0, height=1.0
  ];

  // Stage 2 cluster
  subgraph cluster_stage2 {
    label=<<B>Stage 2 -- Art Generation</B><BR/><FONT POINT-SIZE="9" COLOR="#555555">image generation, high cost</FONT>>;
    style="rounded,filled"; fillcolor="#FFF3E0"; color="#FFB74D";
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif"; fontsize=12;
    margin=16;

    // Parallel fork point
    fork [label="", shape=point, width=0.15, color="#FF9800"];

    characters [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>5. Character Design</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#E65100">character-designer</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">foreach, parallel 2</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">uses metadata.agent_id for visuals</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">stores metadata with character</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D",
      width=2.6
    ];

    panels [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>6. Panel Art</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#E65100">panel-artist</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">foreach, parallel 2 + self-review</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">uses aspect_ratio from layout</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">landscape / portrait / square</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D",
      width=2.6
    ];

    cover [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>7. Cover Art</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#E65100">cover-artist</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">concurrent with panels</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D",
      width=2.2
    ];

    // Join point
    join [label="", shape=point, width=0.15, color="#FF9800"];

    composition [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>8. Composition</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#E65100">strip-compositor</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">uses page_layouts for grid assembly</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">text/speech styling per balloon type</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">SFX: size, color, placement by intensity</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">+ agent_id → dialog voice per character</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">+ visual QA via visual-documenter</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D",
      width=2.8
    ];

    fork -> characters [color="#FFB74D"];
    characters -> panels [color="#FFB74D", label=<<FONT POINT-SIZE="8">character_uris</FONT>>];
    fork -> cover [color="#FFB74D"];
    panels -> join [color="#FFB74D"];
    cover -> join [color="#FFB74D"];
    join -> composition [color="#FFB74D"];
  }

  // Output
  output [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
      <TR><TD><B>comic.html</B></TD></TR>
      <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">Self-contained, open in browser</FONT></TD></TR>
    </TABLE>>,
    shape=note, style="filled", fillcolor="#E8F5E9", color="#81C784",
    width=2.0
  ];

  // Main flow edges
  input -> init [lhead=cluster_stage1, color="#90CAF9"];
  update_title -> storyboard_data [ltail=cluster_stage1, color="#2E7D32", style=dashed];
  storyboard_data -> gate [color="#F9A825"];
  gate -> fork [lhead=cluster_stage2, color="#FFB74D"];
  composition -> output [ltail=cluster_stage2, color="#81C784"];
}
