digraph pipeline {
  // Global settings
  rankdir=TB;
  bgcolor="transparent";
  fontname="Helvetica Neue,Helvetica,Arial,sans-serif";
  node [fontname="Helvetica Neue,Helvetica,Arial,sans-serif", fontsize=11];
  edge [fontname="Helvetica Neue,Helvetica,Arial,sans-serif", fontsize=9];
  newrank=true;
  compound=true;
  splines=ortho;
  nodesep=0.5;
  ranksep=0.6;

  // Title
  labelloc="t";
  label=<<B><FONT POINT-SIZE="16">Comic Generation Pipeline v8.0.0</FONT></B>>;
  labeljust="c";

  // Input
  input [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
      <TR><TD><B>source (flexible)</B></TD></TR>
      <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">project name, session ID(s),</FONT></TD></TR>
      <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">file path(s), or description</FONT></TD></TR>
    </TABLE>>,
    shape=note, style="filled", fillcolor="#E8F4FD", color="#90CAF9",
    width=2.2
  ];

  // ── Stage 1: Saga Planning ─────────────────────────────────────────────────
  subgraph cluster_stage1 {
    label=<<B>Stage 1 — Saga Planning</B><BR/><FONT POINT-SIZE="9" COLOR="#555555">text-only, low cost</FONT>>;
    style="rounded,filled"; fillcolor="#F5F5F5"; color="#BDBDBD";
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif"; fontsize=12;
    margin=16;

    init [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>0. Init Project</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">style-curator</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.2
    ];

    discover_sessions [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>0a. Discover Sessions</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">stories:story-researcher</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">resolves {{source}}</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.4
    ];

    research [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>1. Research</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">stories:story-researcher</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.2
    ];

    style_curation [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>2. Style Curation</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">style-curator</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.2
    ];

    storyboard [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>3. Saga Storyboard</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">storyboard-writer</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">produces issues[], character_roster[]</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.8
    ];

    validate_storyboard [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>3a. Validate Storyboard</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">style-curator</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#C62828">validates layouts across ALL issues</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFEBEE", color="#EF9A9A",
      width=2.6
    ];

    create_issues [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>3b. Create Issues</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#1565C0">style-curator</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">foreach issue in saga_plan.issues[]</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E3F2FD", color="#90CAF9",
      width=2.4
    ];

    init -> discover_sessions -> research -> style_curation -> storyboard -> validate_storyboard -> create_issues [color="#90CAF9"];
  }

  // Data flow annotation — Stage 1 → Approval Gate
  stage1_data [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32"><B>Stage 1 outputs:</B></FONT></TD></TR>
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">saga_plan (arc, issues[], per-issue storyboard slices)</FONT></TD></TR>
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">character_roster[] → Stage 2</FONT></TD></TR>
    </TABLE>>,
    shape=none, margin=0
  ];

  // Approval gate
  gate [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
      <TR><TD><B>APPROVAL GATE</B></TD></TR>
      <TR><TD><FONT POINT-SIZE="9">Shows saga arc, all issues, roster &amp; validation</FONT></TD></TR>
    </TABLE>>,
    shape=diamond, style="filled", fillcolor="#FFF9C4", color="#F9A825",
    width=3.2, height=1.0
  ];

  // ── Stage 2: Character Design ──────────────────────────────────────────────
  subgraph cluster_stage2 {
    label=<<B>Stage 2 — Character Design</B><BR/><FONT POINT-SIZE="9" COLOR="#555555">cross-project search · per-issue variants</FONT>>;
    style="rounded,filled"; fillcolor="#F1F8E9"; color="#81C784";
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif"; fontsize=12;
    margin=16;

    character_design [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>4. Character Design</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#2E7D32">character-designer</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">foreach character in character_roster[]</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">cross-project visual search</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">generates per-issue variants</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#E8F5E9", color="#81C784",
      width=2.8
    ];
  }

  // Data flow annotation — Stage 2 → Stage 3
  stage2_data [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32"><B>Into Stage 3:</B></FONT></TD></TR>
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">character variant URIs (from Stage 2)</FONT></TD></TR>
      <TR><TD><FONT POINT-SIZE="8" COLOR="#2E7D32">per-issue storyboard slices (from Stage 1)</FONT></TD></TR>
    </TABLE>>,
    shape=none, margin=0
  ];

  // ── Stage 3: Per-Issue Art Generation ─────────────────────────────────────
  // Dashed border = foreach loop — repeats for every issue in saga_plan.issues[]
  subgraph cluster_stage3 {
    label=<<B>Stage 3 — Per-Issue Art Generation</B><BR/><FONT POINT-SIZE="9" COLOR="#555555">↻ foreach issue in saga_plan.issues[] — image generation, high cost</FONT>>;
    style="rounded,filled,dashed"; fillcolor="#FFF3E0"; color="#FFB74D";
    fontname="Helvetica Neue,Helvetica,Arial,sans-serif"; fontsize=12;
    margin=16;

    // Parallel fork point
    fork [label="", shape=point, width=0.15, color="#FF9800"];

    panels [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>5. Panel Art</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#E65100">panel-artist</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">foreach panel</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">issue-specific variant URIs</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D",
      width=2.6
    ];

    cover [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>6. Cover Art</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#E65100">cover-artist</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">issue-scoped characters only</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D",
      width=2.2
    ];

    // Join point
    join [label="", shape=point, width=0.15, color="#FF9800"];

    composition [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="2">
        <TR><TD><B>7. Composition</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="9" COLOR="#E65100">strip-compositor</FONT></TD></TR>
        <TR><TD><FONT POINT-SIZE="8" COLOR="#666666">recap page, cliffhanger teaser</FONT></TD></TR>
      </TABLE>>,
      shape=box, style="rounded,filled", fillcolor="#FFE0B2", color="#FFB74D",
      width=2.6
    ];

    fork -> panels [color="#FFB74D"];
    fork -> cover [color="#FFB74D"];
    panels -> join [color="#FFB74D"];
    cover -> join [color="#FFB74D"];
    join -> composition [color="#FFB74D"];
  }

  // Output — one HTML file per issue
  output [
    label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
      <TR><TD><B>issue-001.html, issue-002.html, …</B></TD></TR>
      <TR><TD><FONT POINT-SIZE="9" COLOR="#666666">one self-contained HTML per issue</FONT></TD></TR>
    </TABLE>>,
    shape=note, style="filled", fillcolor="#E8F5E9", color="#81C784",
    width=3.0
  ];

  // ── Main flow edges ────────────────────────────────────────────────────────
  input -> init             [lhead=cluster_stage1, color="#90CAF9"];
  create_issues -> stage1_data [ltail=cluster_stage1, color="#2E7D32", style=dashed];
  stage1_data -> gate       [color="#F9A825"];
  gate -> character_design  [lhead=cluster_stage2, color="#81C784"];
  character_design -> stage2_data [ltail=cluster_stage2, color="#2E7D32", style=dashed];
  stage2_data -> fork       [lhead=cluster_stage3, color="#FFB74D"];
  composition -> output     [ltail=cluster_stage3, color="#81C784"];
}
